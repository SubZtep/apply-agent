{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": {}
    }
  },
  "instructions": [
    ".cursor/rules/*.mdc",
    "docs/config.md",
    "docs/folders.md",
    "docs/states.md"
  ],
  "permission": {
    "read": {
      "*.env": "allow",
      "*.env.local": "allow"
    },
    "edit": {
      "*.env.local": "allow"
    }
  }
}
